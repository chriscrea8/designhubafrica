  cacCertificateUrl String?
  cacNumber        String?
  businessAddressProofUrl String?
  utilityBillUrl   String?
  storefrontImages String[]
  ownerIdFrontUrl  String?
  ownerIdBackUrl   String?
  ownerSelfieUrl   String?
  idType           String?
  instagramUrl     String?
  facebookUrl      String?
  linkedinUrl      String?
  submittedAt      DateTime?
  reviewedAt       DateTime?
  reviewedBy       String?
  rejectionReason  String?   @db.Text
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  business  Business            @relation("BusinessVerif", fields: [businessId], references: [id], onDelete: Cascade)
