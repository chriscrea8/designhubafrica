model Business {
  id                  String   @id @default(cuid())
  ownerUserId         String
  slug                String   @unique
  businessType        String   // DESIGN_FIRM | VENDOR | ARTISAN_COMPANY
  businessName        String
  cacNumber           String?
  businessEmail       String?
  businessPhone       String?
  businessDescription String?  @db.Text
  websiteUrl          String?
  yearEstablished     Int?
  employeeCount       Int?
  address             String?
  city                String?
  state               String?
  country             String   @default("Nigeria")
  googleMapsUrl       String?
  logoUrl             String?
  coverImageUrl       String?
  verificationLevel   String   @default("LEVEL_0_UNVERIFIED")
  verificationStatus  String   @default("UNVERIFIED")
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  owner         User                  @relation("UserBusiness", fields: [ownerUserId], references: [id])
  members       BusinessMember[]      @relation("BusinessMembers")
  verification  BusinessVerification? @relation("BusinessVerif")
