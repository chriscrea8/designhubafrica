generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

// ── NextAuth ────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

// ── Users + RBAC ────────────────────────────

enum UserRole {
  CLIENT
  DESIGNER
  ARTISAN
  VENDOR
  ADMIN
}

enum AdminRole {
  MODERATOR
  ADMIN
  SUPER_ADMIN
  FINANCE_ADMIN
  KYC_REVIEWER
  DISPUTE_MANAGER
  SUPPORT_AGENT
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
}

model User {
  id            String     @id @default(cuid())
  firstName     String
  lastName      String
  email         String     @unique
  emailVerified DateTime?
  password      String?
  image         String?
  phone         String?
  location      String?
  bio           String?    @db.Text
  role          UserRole   @default(CLIENT)
  adminRole     AdminRole?
  status        UserStatus @default(ACTIVE)
  isVerified    Boolean    @default(false)
  createdAt     DateTime   @default(now())
  referralCode  String?    @unique
  deactivatedAt  DateTime?
  termsAcceptedAt DateTime?
  termsVersion    String?
  deleteAfter   DateTime?
  updatedAt     DateTime   @updatedAt

  accounts          Account[]
  sessions          Session[]
  designerProfile   DesignerProfile?
  artisanProfile    ArtisanProfile?
  vendorProfile     VendorProfile?
  clientProjects    Project[]                @relation("ClientProjects")
  savedDesigners    SavedDesigner[]
  orders            Order[]
  reviewsAuthored   Review[]                 @relation("ReviewAuthor")
  reviewsReceived   Review[]                 @relation("ReviewTarget")
  sentMessages      Message[]                @relation("MessageSender")
  notifications     Notification[]
  conversationUsers ConversationParticipant[]
  disputesFiled     Dispute[]                @relation("DisputeFiler")
  disputesAgainst   Dispute[]                @relation("DisputeTarget")
  strikes           UserStrike[]
  suspensions       UserSuspension[]
  clientConsultations Consultation[]         @relation("ClientConsultations")
  clientInvoices      Invoice[]              @relation("ClientInvoices")
  savedProducts       SavedProduct[]         @relation("UserSavedProducts")
  transactions        Transaction[]          @relation("UserTransactions")
  clientBookings      ConsultationBooking[]  @relation("ClientBookings")
  clientMilestoneInvoices MilestoneInvoice[] @relation("ClientMilestoneInvoices")
  moodboards       Moodboard[]           @relation("ClientMoodboards")
  businesses       Business[]            @relation("UserBusiness")
  businessMembers  BusinessMember[]      @relation("UserBusinessMemberships")
  siteVisits       SiteVisit[]           @relation("UserSiteVisits")
  deliverables     Deliverable[]         @relation("UserDeliverables")
  activityLogs     ProjectActivityLog[]  @relation("UserActivityLogs")
  businessReviews  BusinessReview[]      @relation("ClientBusinessReviews")
  adminAuditLogs   VerificationAuditLog[] @relation("AdminAuditLogs")
  productInquiries ProductInquiry[]      @relation("UserInquiries")
  vendorReviews    VendorReview[]         @relation("UserVendorReviews")
  rfqs             RFQ[]                  @relation("ClientRFQs")
  savedQuotes      SavedQuote[]           @relation("UserSavedQuotes")
  marketplaceLeads MarketplaceLead[]      @relation("UserLeads")
  journeyEvents    BuyerJourneyEvent[]    @relation("UserJourneyEvents")
  recentSearches   RecentSearch[]         @relation("UserRecentSearches")
  clientJobRequests   JobRequest[]           @relation("ClientJobRequests")
  artisanReviewsGiven ArtisanReview[]        @relation("ArtisanReviewAuthor")
  supportTickets      SupportTicket[]        @relation("UserTickets")

  @@index([email])
  @@index([role])
  @@index([status])
}

// ── Designer ────────────────────────────────

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum VerificationLevel {
  UNVERIFIED
  BASIC
  PREMIUM
  ELITE
}

model DesignerProfile {
  id              String            @id @default(cuid())
  userId          String            @unique
  specialties     String[]
  hourlyRate      Int               @default(0)
  currency        String            @default("NGN")
  yearsExperience Int               @default(0)
  certifications  String[]
  languages       String[]
  designTools     String[]
  isAvailable     Boolean           @default(true)
  responseTime    String?
  approvalStatus  ApprovalStatus    @default(PENDING)
  verificationLevel VerificationLevel @default(UNVERIFIED)
  approvedAt      DateTime?
  rejectedReason  String?
  avgRating       Float             @default(0)
  totalReviews    Int               @default(0)
  completionRate  Float             @default(0)
  consultationPrice  Int?
  consultationTypes  String?
  meetingLink        String?
  companyName        String?
  companyRegNumber   String?
  isCompany          Boolean  @default(false)
  bio                String?  @db.Text
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user             User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  portfolio        PortfolioItem[]
  servicePackages  ServicePackage[]
  proposals        Proposal[]
  designerProjects Project[]             @relation("DesignerProjects")
  reviews          Review[]              @relation("ReviewDesigner")
  savedBy          SavedDesigner[]
  verification     DesignerVerification?
  subscription     Subscription?
  trustScore       TrustScore?
  consultations    Consultation[]
  availabilitySlots AvailabilitySlot[]
  featuredListing  FeaturedDesigner?
  invoices         Invoice[]         @relation("DesignerInvoices")
  packages         ConsultationPackage[] @relation("DesignerPackages")
  inspirations     Inspiration[]         @relation("DesignerInspirations")
  designerBookings ConsultationBooking[] @relation("DesignerBookings")
  milestoneInvoices MilestoneInvoice[]   @relation("DesignerMilestoneInvoices")

  @@index([approvalStatus])
  @@index([isAvailable])
  @@index([avgRating])
}

model DesignerVerification {
  id                String   @id @default(cuid())
  designerId        String   @unique
  governmentIdUrl   String?
  selfieUrl         String?
  portfolioCount    Int      @default(0)
  declaredTools     String[]
  experienceYears   Int?
  step              String   @default("NOT_STARTED")
  reviewedBy        String?
  reviewNotes       String?  @db.Text
  rejectedReason    String?
  completedAt       DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  designer          DesignerProfile @relation(fields: [designerId], references: [id], onDelete: Cascade)
}

model PortfolioItem {
  id          String   @id @default(cuid())
  designerId  String
  title       String
  description String?  @db.Text
  images      String[]
  category    String
  style       String
  location    String?
  isFeatured  Boolean  @default(false)
  views       Int      @default(0)
  likes       Int      @default(0)
  completedAt DateTime?
  createdAt   DateTime @default(now())
  designer    DesignerProfile @relation(fields: [designerId], references: [id], onDelete: Cascade)
  @@index([designerId])
}

model ServicePackage {
  id           String   @id @default(cuid())
  designerId   String
  title        String
  description  String   @db.Text
  price        Int
  currency     String   @default("NGN")
  deliveryDays Int
  isActive     Boolean  @default(true)
  ordersCount  Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  designer     DesignerProfile @relation(fields: [designerId], references: [id], onDelete: Cascade)
  @@index([designerId])
}

// ── Vendor ──────────────────────────────────

model VendorProfile {
  id               String         @id @default(cuid())
  userId           String         @unique
  storeName        String
  storeDescription String?        @db.Text
  storeImage       String?
  category         String?
  approvalStatus   ApprovalStatus @default(PENDING)
  approvedAt       DateTime?
  rejectedReason   String?
  avgRating        Float          @default(0)
  totalReviews     Int            @default(0)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  products         Product[]
  verification     VendorVerification?
  subscription        VendorSubscription?    @relation("VendorPlan")
  inquiries           ProductInquiry[]       @relation("VendorInquiries")
  vendorReviews       VendorReview[]         @relation("VendorProfileReviews")
  rfqs                RFQ[]                  @relation("VendorRFQs")
  vendorQuotes        VendorQuote[]          @relation("VendorQuotes")
  marketplaceLeads    MarketplaceLead[]      @relation("VendorLeads")
  subscriptionsV2     VendorSubscriptionV2[] @relation("VendorSubV2")
  promotedProducts    PromotedProduct[]      @relation("VendorPromotions")
  featuredStores      FeaturedStore[]        @relation("VendorFeaturedStore")
  advertisements      Advertisement[]        @relation("VendorAds")
  promotionTxns       PromotionTransaction[] @relation("VendorPromotionTxns")
  @@index([approvalStatus])
}

model VendorVerification {
  id                String   @id @default(cuid())
  vendorId          String   @unique
  status            String   @default("UNVERIFIED")
  governmentIdUrl   String?
  businessRegUrl    String?
  businessRegNumber String?
  phoneVerified     Boolean  @default(false)
  phoneNumber       String?
  businessAddress   String?
  addressProofUrl   String?
  reviewedBy        String?
  reviewNotes       String?  @db.Text
  rejectedReason    String?
  verifiedAt        DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  vendor            VendorProfile @relation(fields: [vendorId], references: [id], onDelete: Cascade)
}

// ── Artisan Profile ─────────────────────────

model ArtisanProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  serviceCategory String   // carpenter, electrician, painter, tiler, plumber, furniture_maker, pop_installer
  specialties     String[]
  hourlyRate      Int      @default(0)
  currency        String   @default("NGN")
  yearsExperience Int      @default(0)
  certifications  String[]
  languages       String[]
  tools           String[]
  isAvailable     Boolean  @default(true)
  responseTime    String?
  workLocations   String[] // Areas they serve
  approvalStatus  String   @default("PENDING")
  approvedAt      DateTime?
  rejectedReason  String?
  avgRating       Float    @default(0)
  totalReviews    Int      @default(0)
  completionRate  Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  bio                String?        @db.Text
  phone              String?
  availabilityStatus String         @default("AVAILABLE")
  user               User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  proposals          Proposal[]     @relation("ArtisanProposals")
  portfolio          ArtisanPortfolio[]  @relation("ArtisanPortfolio")
  verification       ArtisanVerification? @relation("ArtisanVerification")
  artisanReviews     ArtisanReview[]     @relation("ArtisanReviews")
  quotes             JobQuote[]          @relation("ArtisanQuotes")
  reviews         Review[]   @relation("ReviewArtisan")
  contracts       Contract[] @relation("ArtisanContracts")

  @@index([approvalStatus])
  @@index([serviceCategory])
  @@index([isAvailable])
  @@index([avgRating])
}

// ── Contracts ───────────────────────────────

model Contract {
  id               String   @id @default(cuid())
  projectId        String
  clientId         String
  professionalId   String   // Designer or Artisan user ID
  professionalType String   // "designer" or "artisan"
  artisanId        String?  // ArtisanProfile ID if artisan
  totalAmount      Int
  currency         String   @default("NGN")
  commissionRate   Float    @default(0.10)
  status           String   @default("DRAFT") // DRAFT, ACTIVE, COMPLETED, CANCELLED, DISPUTED
  startDate        DateTime?
  endDate          DateTime?
  completedAt      DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  project          Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  artisan          ArtisanProfile? @relation("ArtisanContracts", fields: [artisanId], references: [id])

  @@index([projectId])
  @@index([clientId])
  @@index([professionalId])
  @@index([status])
}

model Subscription {
  id               String   @id @default(cuid())
  designerId       String   @unique
  plan             String   @default("FREE")
  billingCycle     String   @default("MONTHLY")
  price            Int      @default(0)
  currency         String   @default("NGN")
  isActive         Boolean  @default(true)
  currentPeriodEnd DateTime?
  paymentRef       String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  designer         DesignerProfile @relation(fields: [designerId], references: [id], onDelete: Cascade)
}

// ── Promotions ──────────────────────────────

model Promotion {
  id           String   @id @default(cuid())
  type         String
  targetId     String
  targetType   String
  price        Int
  currency     String   @default("NGN")
  durationDays Int
  isActive     Boolean  @default(false)
  startsAt     DateTime?
  endsAt       DateTime?
  paymentRef   String?
  impressions  Int      @default(0)
  clicks       Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  @@index([type, isActive])
}

// ── Projects + Escrow ───────────────────────

model Project {
  id              String   @id @default(cuid())
  title           String
  description     String   @db.Text
  clientId        String
  designerId      String?
  status          String   @default("DRAFT")
  roomType        String
  style           String
  budgetMin       Int
  budgetMax       Int
  currency        String   @default("NGN")
  startDate       DateTime?
  endDate         DateTime?
  progress        Int      @default(0)
  viewCount       Int      @default(0)
  location        String?
  images          String[]
  urgency         String?
  commissionRate  Float    @default(0.10)
  clientFeeRate   Float    @default(0.05)
  designerFeeRate Float    @default(0.05)
  platformFee     Int      @default(0)
  businessId      String?
  timeline        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  client        User              @relation("ClientProjects", fields: [clientId], references: [id])
  designer      DesignerProfile?  @relation("DesignerProjects", fields: [designerId], references: [id])
  business      Business?         @relation("BusinessProjects", fields: [businessId], references: [id])
  siteVisits    SiteVisit[]       @relation("ProjectSiteVisits")
  deliverables  Deliverable[]     @relation("ProjectDeliverables")
  activityLogs  ProjectActivityLog[] @relation("ProjectActivity")
  tasks         ProjectTask[]
  proposals     Proposal[]
  milestones    Milestone[]
  projectFiles  ProjectFile[]
  conversations Conversation[]
  disputes      Dispute[]
  contracts     Contract[]
  invoices      Invoice[]
  reviews           Review[]         @relation("ReviewProject")
  milestoneInvoices MilestoneInvoice[] @relation("ProjectMilestoneInvoices")

  @@index([clientId])
  @@index([designerId])
  @@index([status])
}

model ProjectTask {
  id          String    @id @default(cuid())
  projectId   String
  title       String
  description String?   @db.Text
  status      String    @default("pending")
  assigneeId  String?
  dueDate     DateTime?
  priority    String    @default("medium")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  @@index([projectId])
}

model Milestone {
  id                 String              @id @default(cuid())
  projectId          String
  title              String
  description        String?             @db.Text
  amount             Int
  currency           String              @default("NGN")
  status             String              @default("pending")
  dueDate            DateTime?
  completedAt        DateTime?
  approvedAt         DateTime?
  paidAt             DateTime?
  createdAt          DateTime            @default(now())
  invoice            MilestoneInvoice?   @relation("MilestoneInvoice")
  project            Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  @@index([projectId])
}

model Proposal {
  id           String   @id @default(cuid())
  projectId    String
  designerId   String?
  artisanId    String?
  coverLetter  String   @db.Text
  proposedRate Int
  currency     String   @default("NGN")
  deliveryDays Int
  milestones   String?  @db.Text // JSON array of { title, amount, deliverable, durationDays }
  status       String   @default("pending") // pending, accepted, rejected, revision_requested
  clientNotes  String?  @db.Text // Client feedback when requesting changes
  expiresAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  project      Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  designer     DesignerProfile? @relation(fields: [designerId], references: [id], onDelete: Cascade)
  artisan      ArtisanProfile?  @relation("ArtisanProposals", fields: [artisanId], references: [id], onDelete: Cascade)
  @@index([projectId])
  @@index([designerId])
  @@index([artisanId])
}

model ProjectFile {
  id         String   @id @default(cuid())
  projectId  String
  name       String
  url        String
  type       String
  size       Int?
  uploadedBy String
  createdAt  DateTime @default(now())
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  @@index([projectId])
}

// ── Escrow ──────────────────────────────────



// ── Disputes ────────────────────────────────

model Dispute {
  id           String    @id @default(cuid())
  projectId    String
  filerId      String
  targetId     String
  status       String    @default("OPEN")
  reason       String    @db.Text
  evidence     String[]
  outcome      String?
  refundAmount Int?
  adminNotes   String?   @db.Text
  resolvedBy   String?
  resolvedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  project      Project   @relation(fields: [projectId], references: [id])
  filer        User      @relation("DisputeFiler", fields: [filerId], references: [id])
  target       User      @relation("DisputeTarget", fields: [targetId], references: [id])
  @@index([projectId])
  @@index([status])
}

// ── Marketplace ─────────────────────────────

model ProductCategory {
  id           String            @id @default(cuid())
  name         String            @unique
  slug         String            @unique
  icon         String?
  isActive     Boolean           @default(true)
  sortOrder    Int               @default(0)
  parentId     String?
  createdAt    DateTime          @default(now())
  products     Product[]
  parent       ProductCategory?  @relation("CategoryTree", fields: [parentId], references: [id])
  children     ProductCategory[] @relation("CategoryTree")
}

model Product {
  id                   String           @id @default(cuid())
  vendorId             String
  savedByUsers         SavedProduct[]   @relation("ProductSaves")
  boosts               ProductBoost[]   @relation("ProductBoosts")
  inquiries            ProductInquiry[]  @relation("ProductInquiries")
  rfqs                 RFQ[]             @relation("ProductRFQs")
  marketplaceLeads     MarketplaceLead[] @relation("ProductLeads")
  promotedProducts     PromotedProduct[] @relation("ProductPromotions")
  name                 String
  slug                 String?          @unique
  brand                String?
  description          String           @db.Text
  priceMin             Int              @default(0)
  priceMax             Int              @default(0)
  price                Int
  currency             String           @default("NGN")
  condition            String           @default("NEW")  // NEW | USED | REFURBISHED
  availabilityStatus   String           @default("IN_STOCK")  // IN_STOCK | LOW_STOCK | OUT_OF_STOCK | ON_REQUEST
  categoryId           String?
  category             String
  images               String[]
  inStock              Boolean          @default(true)
  stockCount           Int              @default(0)
  dimensions           String?
  material             String?
  color                String?
  tags                 String[]
  viewCount            Int              @default(0)
  favouritesCount      Int              @default(0)
  moderationStatus     String           @default("DRAFT")
  moderationNote       String?
  moderatedBy          String?
  moderatedAt          DateTime?
  isApproved           Boolean          @default(false)
  commissionPercentage Float            @default(0.10)
  platformCommission   Int              @default(0)
  // Delivery options
  deliveryMethod       String?          // "pickup", "delivery", "both"
  shippingCost         Int              @default(0)
  estimatedDeliveryDays Int?
  weight               Float?           // in kg
  freeDeliveryAbove    Int?             // free delivery if order above this amount
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  vendor               VendorProfile    @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  productCategory      ProductCategory? @relation(fields: [categoryId], references: [id])
  orderItems           OrderItem[]
  reviews              Review[]
  @@index([vendorId])
  @@index([category])
  @@index([moderationStatus])
  @@index([isApproved])
}

model Order {
  id                String    @id @default(cuid())
  userId            String
  totalAmount       Int
  currency          String    @default("NGN")
  status            String    @default("pending")
  shippingAddress   String?   @db.Text
  paymentRef        String?
  paidAt            DateTime?
  estimatedDelivery DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  user              User        @relation(fields: [userId], references: [id])
  items             OrderItem[]
  @@index([userId])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Int
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])
  @@index([orderId])
}

// ── Reviews ─────────────────────────────────

model Review {
  id                    String   @id @default(cuid())
  authorId              String
  targetUserId          String?
  designerId            String?
  artisanId             String?
  productId             String?
  projectId             String?
  rating                Int
  comment               String?  @db.Text
  qualityRating         Int?
  communicationRating   Int?
  timelinessRating      Int?
  professionalismRating Int?
  createdAt             DateTime @default(now())
  author                User             @relation("ReviewAuthor", fields: [authorId], references: [id])
  target                User?            @relation("ReviewTarget", fields: [targetUserId], references: [id])
  designer              DesignerProfile? @relation("ReviewDesigner", fields: [designerId], references: [id])
  artisan               ArtisanProfile?  @relation("ReviewArtisan", fields: [artisanId], references: [id])
  product               Product?         @relation(fields: [productId], references: [id])
  project               Project?         @relation("ReviewProject", fields: [projectId], references: [id])
  @@index([designerId])
  @@index([artisanId])
  @@index([productId])
}

// ── Messaging ───────────────────────────────

model Conversation {
  id           String                    @id @default(cuid())
  projectId    String?
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
  project      Project?                  @relation(fields: [projectId], references: [id])
  participants ConversationParticipant[]
  messages     Message[]
  @@index([projectId])
}

model ConversationParticipant {
  id             String       @id @default(cuid())
  conversationId String
  userId         String
  lastReadAt     DateTime?
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id])
  @@unique([conversationId, userId])
  @@index([userId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  content        String       @db.Text
  type           String       @default("text")
  fileUrl        String?
  isFlagged      Boolean      @default(false)
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation("MessageSender", fields: [senderId], references: [id])
  @@index([conversationId])
  @@index([senderId])
}

// ── Anti-Bypass Messaging Moderation ────────

model MessageModeration {
  id               String   @id @default(cuid())
  conversationId   String
  senderId         String
  originalContent  String   @db.Text
  sanitizedContent String?  @db.Text
  severity         String   @default("CLEAN")
  violations       String[]
  violationDetails Json?
  action           String
  wasDelivered     Boolean  @default(true)
  createdAt        DateTime @default(now())
  @@index([senderId])
  @@index([severity])
}

model UserStrike {
  id        String   @id @default(cuid())
  userId    String
  type      String
  reason    String   @db.Text
  severity  String
  sourceId  String?
