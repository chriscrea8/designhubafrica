  projects      Project[]             @relation("BusinessProjects")

  @@index([ownerUserId])
  @@index([businessType])
  @@index([verificationStatus])
}

model BusinessVerification {
  id               String    @id @default(cuid())
  businessId       String    @unique
  verificationLevel String   @default("LEVEL_0_UNVERIFIED")
