  createdAt DateTime @default(now())

  vendor VendorProfile @relation("VendorProfileReviews", fields: [vendorId], references: [id])
  user   User          @relation("UserVendorReviews", fields: [userId], references: [id])
  @@unique([vendorId, userId])
  @@index([vendorId])
}

// ── PHASE 21: RFQ, LEAD ATTRIBUTION & MARKETPLACE INTELLIGENCE ─────────────

model RFQ {
  id               String    @id @default(cuid())
  rfqNumber        String    @unique
  clientId         String
  productId        String?
  vendorId         String?
  title            String
  description      String    @db.Text
  quantity         String?
  budgetMin        Float?
  budgetMax        Float?
  deliveryLocation String?
  requiredDate     DateTime?
  status           String    @default("SUBMITTED") // DRAFT|SUBMITTED|QUOTED|ACCEPTED|DECLINED|EXPIRED|CLOSED
  viewCount        Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  client      User           @relation("ClientRFQs",  fields: [clientId], references: [id])
  product     Product?       @relation("ProductRFQs", fields: [productId], references: [id])
  vendor      VendorProfile? @relation("VendorRFQs",  fields: [vendorId],  references: [id])
  attachments RFQAttachment[] @relation("RFQFiles")
  quotes      VendorQuote[]  @relation("RFQQuotes")
  leads       MarketplaceLead[] @relation("RFQLeads")

  @@index([clientId])
  @@index([status])
  @@index([vendorId])
}

model RFQAttachment {
  id        String   @id @default(cuid())
  rfqId     String
  fileUrl   String
  fileType  String
  fileName  String?
  createdAt DateTime @default(now())

  rfq RFQ @relation("RFQFiles", fields: [rfqId], references: [id], onDelete: Cascade)
  @@index([rfqId])
}

model VendorQuote {
  id                   String    @id @default(cuid())
  quoteNumber          String    @unique
  rfqId                String
  vendorId             String
  message              String    @db.Text
  estimatedPriceMin    Float?
  estimatedPriceMax    Float?
  estimatedDelivery    String?
  validUntil           DateTime?
  status               String    @default("SUBMITTED") // DRAFT|SUBMITTED|ACCEPTED|DECLINED|EXPIRED
  responseTimeHours    Float?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  rfq        RFQ           @relation("RFQQuotes",  fields: [rfqId],    references: [id], onDelete: Cascade)
  vendor     VendorProfile @relation("VendorQuotes", fields: [vendorId], references: [id])
  savedBy    SavedQuote[]  @relation("QuoteSaves")

  @@index([rfqId])
  @@index([vendorId])
}

model SavedQuote {
  id        String   @id @default(cuid())
  userId    String
  quoteId   String
  createdAt DateTime @default(now())

  user  User        @relation("UserSavedQuotes", fields: [userId],  references: [id])
  quote VendorQuote @relation("QuoteSaves",      fields: [quoteId], references: [id])
  @@unique([userId, quoteId])
}

model MarketplaceLead {
  id         String   @id @default(cuid())
  leadNumber String   @unique
  sourceType String   // PRODUCT_VIEW|PRODUCT_SAVE|STORE_VISIT|PRODUCT_INQUIRY|RFQ_SUBMITTED|QUOTE_ACCEPTED
  userId     String?
  vendorId   String?
  productId  String?
  rfqId      String?
  status     String   @default("OPEN") // OPEN|ENGAGED|QUOTED|WON|LOST
  metadata   Json?
  createdAt  DateTime @default(now())

  user    User?          @relation("UserLeads",   fields: [userId],   references: [id])
  vendor  VendorProfile? @relation("VendorLeads", fields: [vendorId], references: [id])
  product Product?       @relation("ProductLeads",fields: [productId],references: [id])
  rfq     RFQ?           @relation("RFQLeads",    fields: [rfqId],    references: [id])

  @@index([userId])
  @@index([vendorId])
  @@index([sourceType])
}

model BuyerJourneyEvent {
  id         String   @id @default(cuid())
  userId     String?
  sessionId  String?
  eventType  String   // VIEWED_PRODUCT|SAVED_PRODUCT|VIEWED_STORE|SENT_INQUIRY|SUBMITTED_RFQ|VIEWED_QUOTE|ACCEPTED_QUOTE
  entityType String?  // product|store|rfq|quote
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  user User? @relation("UserJourneyEvents", fields: [userId], references: [id])
  @@index([userId])
  @@index([eventType])
}

model RecentSearch {
  id        String   @id @default(cuid())
  userId    String
  query     String
  category  String?
  createdAt DateTime @default(now())

  user User @relation("UserRecentSearches", fields: [userId], references: [id])
  @@index([userId])
  @@unique([userId, query])
}

// ── PHASE 22: VENDOR MONETIZATION, PROMOTIONS & ADVERTISING ────────────────

model VendorSubscriptionPlan {
  id                    String   @id @default(cuid())
  name                  String   @unique  // FREE | PRO | BUSINESS | ENTERPRISE
  description           String?  @db.Text
  monthlyPrice          Float    @default(0)
  yearlyPrice           Float    @default(0)
  maxProducts           Int      @default(20)
  maxBoostedProducts    Int      @default(0)
  boostCreditsMonthly   Int      @default(0)
  featuredStoreEligible Boolean  @default(false)
  advancedAnalytics     Boolean  @default(false)
  prioritySupport       Boolean  @default(false)
  badgeColor            String?
  status                String   @default("ACTIVE")
  sortOrder             Int      @default(0)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  subscriptions         VendorSubscriptionV2[] @relation("PlanSubscriptions")
}

model VendorSubscriptionV2 {
  id               String    @id @default(cuid())
  vendorId         String
  planId           String
  billingCycle     String    @default("MONTHLY") // MONTHLY | YEARLY
  startDate        DateTime  @default(now())
  endDate          DateTime
  status           String    @default("ACTIVE") // ACTIVE | EXPIRED | CANCELLED | PAST_DUE
  paymentReference String?
  autoRenew        Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  vendor VendorProfile         @relation("VendorSubV2", fields: [vendorId], references: [id])
  plan   VendorSubscriptionPlan @relation("PlanSubscriptions", fields: [planId], references: [id])
  @@index([vendorId])
  @@index([status])
}

model PromotionPlan {
  id           String   @id @default(cuid())
  name         String   @unique   // STARTER | STANDARD | PREMIUM | ELITE
  durationDays Int
  price        Float
  boostScore   Int      @default(50)
  type         String   @default("BOOST") // BOOST | FEATURED | HOMEPAGE | CATEGORY
  description  String?
  status       String   @default("ACTIVE")
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  promotedProducts PromotedProduct[] @relation("PlanPromotions")
}

model PromotedProduct {
  id                String    @id @default(cuid())
  productId         String
  vendorId          String
  promotionPlanId   String
  boostScore        Int       @default(50)
  startDate         DateTime  @default(now())
  endDate           DateTime
  status            String    @default("ACTIVE") // ACTIVE | EXPIRED | CANCELLED
  paymentReference  String?
  impressions       Int       @default(0)
  clicks            Int       @default(0)
  createdAt         DateTime  @default(now())

  product       Product       @relation("ProductPromotions",  fields: [productId],       references: [id], onDelete: Cascade)
  vendor        VendorProfile @relation("VendorPromotions",   fields: [vendorId],         references: [id])
  promotionPlan PromotionPlan @relation("PlanPromotions",     fields: [promotionPlanId], references: [id])
  analytics     PromotionAnalytic[] @relation("PromotedProductAnalytics")
  @@index([productId])
  @@index([vendorId])
  @@index([status])
  @@index([endDate])
}

model FeaturedStore {
  id               String    @id @default(cuid())
  vendorId         String
  startDate        DateTime  @default(now())
  endDate          DateTime
  status           String    @default("ACTIVE")
  paymentReference String?
  impressions      Int       @default(0)
  clicks           Int       @default(0)
  createdAt        DateTime  @default(now())

  vendor VendorProfile @relation("VendorFeaturedStore", fields: [vendorId], references: [id])
  analytics PromotionAnalytic[] @relation("FeaturedStoreAnalytics")
  @@index([vendorId])
  @@index([status])
  @@index([endDate])
}

model AdvertisementSlot {
  id           String   @id @default(cuid())
  name         String
  location     String   // HOMEPAGE_HERO | HOMEPAGE_MID | MARKETPLACE_SIDEBAR | CATEGORY_BANNER
  price        Float
  durationDays Int      @default(7)
  maxActive    Int      @default(3)
  status       String   @default("ACTIVE")
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())

  advertisements Advertisement[] @relation("SlotAds")
}

model Advertisement {
  id               String    @id @default(cuid())
  vendorId         String
  slotId           String
  imageUrl         String
  linkUrl          String?
  headline         String?
  status           String    @default("PENDING") // PENDING | ACTIVE | EXPIRED | REJECTED
  startDate        DateTime?
  endDate          DateTime?
  paymentReference String?
  impressions      Int       @default(0)
  clicks           Int       @default(0)
  approvedBy       String?
  rejectionReason  String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  vendor VendorProfile    @relation("VendorAds",  fields: [vendorId], references: [id])
  slot   AdvertisementSlot @relation("SlotAds",   fields: [slotId],   references: [id])
  analytics PromotionAnalytic[] @relation("AdAnalytics")
  @@index([vendorId])
  @@index([status])
  @@index([endDate])
}

model PromotionTransaction {
  id               String   @id @default(cuid())
  vendorId         String
  amount           Float
  paymentProvider  String   @default("paystack") // paystack | flutterwave
  paymentReference String?  @unique
  status           String   @default("pending")  // pending | successful | failed
  transactionType  String   // BOOST | FEATURED_PRODUCT | FEATURED_STORE | ADVERTISEMENT | SUBSCRIPTION
  referenceId      String?  // promotedProduct.id / featuredStore.id / advertisement.id
  metadata         Json?
  createdAt        DateTime @default(now())

  vendor VendorProfile @relation("VendorPromotionTxns", fields: [vendorId], references: [id])
  @@index([vendorId])
  @@index([status])
  @@index([transactionType])
}

model PromotionAnalytic {
  id                String   @id @default(cuid())
  promotedProductId String?
  featuredStoreId   String?
  advertisementId   String?
  eventType         String   // IMPRESSION | CLICK | STORE_VISIT | PRODUCT_VIEW | RFQ | INQUIRY
  userId            String?
  sessionId         String?
  createdAt         DateTime @default(now())

  promotedProduct PromotedProduct? @relation("PromotedProductAnalytics", fields: [promotedProductId], references: [id])
  featuredStore   FeaturedStore?   @relation("FeaturedStoreAnalytics",   fields: [featuredStoreId],   references: [id])
  advertisement   Advertisement?   @relation("AdAnalytics",              fields: [advertisementId],   references: [id])

  @@index([promotedProductId])
  @@index([featuredStoreId])
  @@index([advertisementId])
  @@index([eventType])
}
